global:
  scrape_interval: 1s
  evaluation_interval: 1s

scrape_configs:
  - job_name: 'node_exporter'
    static_configs:
      - targets:
{% for host in groups['hcloud_label_project_bachelor'] %}
          - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endfor %}

  - job_name: 'besu_nodes'
    metrics_path: /metrics
    static_configs:
      - targets:
{% for host in groups['hcloud_label_role_storage'] %}
          - "{{ hostvars[host]['ansible_host'] }}:9545"
{% endfor %}

  - job_name: 'ipfs_nodes'
    metrics_path: /debug/metrics/prometheus
    static_configs:
      - targets:
{% for host in groups['hcloud_label_role_storage'] %}
          - "{{ hostvars[host]['ansible_host'] }}:5001"
{% endfor %}

  - job_name: 'cadvisor'
    static_configs:
      - targets:
{% for host in groups['hcloud_label_project_bachelor'] %}
          - "{{ hostvars[host]['ansible_host'] }}:8888"
{% endfor %}

  - job_name: 'middleware'
    metrics_path: /metrics
    static_configs:
      - targets:
{% for host in groups['hcloud_label_role_gateway'] %}
          - "{{ hostvars[host]['ansible_host'] }}:8000"
{% endfor %}

  - job_name: 'load_simulator'
    metrics_path: /metrics
    static_configs:
      - targets:
{% for host in groups['hcloud_label_role_control'] %}
          - "{{ hostvars[host]['ansible_host'] }}:9011"
{% endfor %}