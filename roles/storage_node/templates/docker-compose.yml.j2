{% set bootnode_host = 'datahost-fsn1-1' %}
services:
  besu:
    image: hyperledger/besu:26.2.0
    container_name: besu-node
    network_mode: host
    volumes:
      - ./besu-genesis.json:/opt/besu/genesis.json
      - ./node_data:/var/lib/besu
{% if inventory_hostname == bootnode_host %}
      - ./besu_key:/opt/besu/nodekey
    environment:
      - BESU_NODE_PRIVATE_KEY={{ besu_enode_key }}
{% endif %}
    command:
      - --genesis-file=/opt/besu/genesis.json
      - --data-path=/var/lib/besu
      - --network-id=1337
      - --rpc-http-enabled=true
      - --rpc-http-host=0.0.0.0
      - --rpc-http-cors-origins=*
      - --host-allowlist=*
      - --rpc-http-port=8545
      - --p2p-port=30303
      - --metrics-enabled=true
      - --metrics-host=0.0.0.0
      - --metrics-port=9545
      - --rpc-http-api=ETH,NET,WEB3,CLIQUE,MINER
      - --min-gas-price=0
      - --sync-min-peers=1
      - --sync-mode=FULL
      - --p2p-enabled=true
      - --data-storage-format=BONSAI
{% if inventory_hostname == bootnode_host %}
      - --node-private-key-file=/opt/besu/nodekey
{% endif %}
{% if inventory_hostname != bootnode_host %}
      - --bootnodes=enode://{{ besu_bootnode_enode_id }}@{{ hostvars[bootnode_host]['ansible_host'] }}:30303
{% endif %}
      - --p2p-host={{ ansible_host }}

  ipfs:
    image: ipfs/kubo:v0.39.0
    container_name: ipfs-node
    network_mode: host
    environment:
      - IPFS_TELEMETRY=off
      - IPFS_PROFILE=server
      - LIBP2P_FORCE_PNET=1
    volumes:
      - ./ipfs_data:/data/ipfs
    ports:
      - "4001:4001"
      - "5001:5001"
      - "8080:8080"
